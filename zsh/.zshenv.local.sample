# Sample file for specific local environment variables
# To use, cp this file as ~/.zshenv.local and change variables below
ENV_VARS=(
    # You can manage Git variables:
    #GIT_AUTHOR_NAME         "John Doe"
    #GIT_AUTHOR_EMAIL        email@example.org
    #GIT_COMMITTER_NAME      "John Doe"
    #GIT_COMMITTER_EMAIL     email@example.org
    # Or set Vim in a 'lite' mode for it to use less resources
    #VIM_LITE                "true"
)

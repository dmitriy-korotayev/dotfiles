# ----- General -----

snippet t "Tag"
${1:span}${3:} ${2:text}
endsnippet

# ----- Tags -----

snippet s "s"
span
endsnippet
snippet a "Anchor tag"
a href="${2:#}"${3:} $1
endsnippet
snippet img "Image tag"
img src="${1:image.jpg}" alt="${2:Image}"${3:}
endsnippet
snippet f "Form tag"
form method="${1:post}" action="${2:/}"
endsnippet

# ----- Components -----

# includes
snippet css "css"
link rel="stylesheet" href="${1:css/style.css}" media="screen"
endsnippet
snippet js "js"
script src="${1:/js/script.js}"
endsnippet

# form
snippet fl "form > label"
label for="${1:name}"${3:} ${2: text}
endsnippet
snippet fi "form > input"
input name="${1:}" id="`!p
snip.rv = t[1].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_')
`" placeholder="${2:}" value="${3:}"
endsnippet
snippet fiu "form > input[type=unique(password/file)]"
input type="${1:password}" name="${2:}" id="`!p
snip.rv = t[2].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_')
`"
endsnippet
snippet fit "form > input[type=toggleable(checkbox/radio)]"
input type="${1:checkbox}" name="${2:}" id="`!p
snip.rv = t[2].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_') + '_' + t[3]
`" value="${3:1}"
endsnippet
snippet ft "form > textarea"
textarea name="${1:}" id="`!p
snip.rv = t[1].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_')
`" placeholder="${2:}" value="${3:}"
endsnippet
snippet fs "form > select"
select name="${1:submit}" id="`!p
snip.rv = t[1].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_')
`"
  option value="${8:1}"${5: selected=true} ${2: Value 1}
  option value="${9:2}"${6:} ${3: Value 2}
  option value="${10:3}"${7:} ${4: Value 3}
endsnippet
snippet fis "form > input [type=submit]"
input type="submit" name="${2:submit}" id="`!p
snip.rv = t[2].replace('[]','').replace('][','_').replace('[','_').replace(']','').replace(' ','_')
`" value="${1:}"
endsnippet


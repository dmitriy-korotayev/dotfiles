# Applications
###################

# --- Autostart apps ---

# http://i3wm.org/docs/userguide.html#_automatically_starting_applications_on_i3_startup

exec xneur
exec thunar --daemon

#exec skype
exec nm-applet
exec dropbox start -i
exec megasync
exec --no-startup-id upmpdcli

exec --no-startup-id dunst
exec redshift-gtk
exec autorandr --change --default laptop

[user]
	name = Dmitriy Korotayev
	email = korotayev.dmitriy@gmail.com
[alias]
	st = status
	ci = commit
	co = checkout
	br = branch
[core]
	excludesfile = /home/dmitriy/.gitignore
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[credential]
	helper = cache --timeout=3600
[push]
	default = simple
[http]
	postBuffer = 256000000 # not 524288000 because Raspberry Pi fails on that

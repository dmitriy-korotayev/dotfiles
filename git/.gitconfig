[user]
    ;name = $GIT_AUTHOR_NAME
    ;email = $GIT_AUTHOR_EMAIL
[alias]
    st = status
    ci = commit
    co = checkout
    br = branch
[core]
    excludesfile = ~/.gitignore
[color]
    branch = auto
    diff = auto
    interactive = auto
    status = auto
[credential]
    helper = cache --timeout=3600
[push]
    default = simple
[http]
    postBuffer = 256000000 # not 524288000 because Raspberry Pi fails on that
[init]
	templatedir = /home/dmitriy/.git-templates
